{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install"
  },
  "deploy": {
    "startCommand": "npm run start:poc",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "environments": {
    "production": {
      "build": {
        "nixpacksPlan": {
          "providers": ["node"],
          "phases": {
            "setup": {
              "nixPkgs": ["nodejs-20_x"]
            }
          }
        }
      }
    }
  }
}
