{
  "_version": "1.65.0",
  "sap.app": {
    "id": "sains.ar.financialreporting",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": { "version": "2.0.0" },
    "dataSources": {
      "mainService": {
        "uri": "/ar/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      },
      "reportingService": {
        "uri": "/reporting/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": { "sap.m": {}, "sap.ui.core": {}, "sap.fe.templates": {}, "sap.fe.core": {} }
    },
    "models": {
      "": {
        "dataSource": "reportingService",
        "settings": { "synchronizationMode": "None", "operationMode": "Server" }
      },
      "ar": {
        "dataSource": "mainService",
        "settings": { "synchronizationMode": "None", "operationMode": "Server" }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "sains.ar.financialreporting.i18n.i18n" }
      }
    },
    "routing": {
      "config": { "routerClass": "sap.fe.core.AppComponent" },
      "routes": [
        { "pattern": "", "name": "ReportDashboard", "target": "ReportDashboard" },
        { "pattern": "BadDebtProvisions({key})", "name": "ProvisionObjectPage", "target": "ProvisionObjectPage" },
        { "pattern": "PeriodCloseChecklists({key})", "name": "ChecklistObjectPage", "target": "ChecklistObjectPage" },
        { "pattern": "ReconciliationRecords({key})", "name": "ReconciliationObjectPage", "target": "ReconciliationObjectPage" }
      ],
      "targets": {
        "ReportDashboard": {
          "type": "Component", "id": "ReportDashboard",
          "name": "sap.fe.templates.ListReport",
          "options": { "settings": { "entitySet": "PeriodCloseChecklists", "variantManagement": "Page" } }
        },
        "ProvisionObjectPage": {
          "type": "Component", "id": "ProvisionObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": { "settings": { "entitySet": "BadDebtProvisions" } }
        },
        "ChecklistObjectPage": {
          "type": "Component", "id": "ChecklistObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": { "settings": { "entitySet": "PeriodCloseChecklists" } }
        },
        "ReconciliationObjectPage": {
          "type": "Component", "id": "ReconciliationObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": { "settings": { "entitySet": "ReconciliationRecords" } }
        }
      }
    }
  }
}
