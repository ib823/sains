{
  "_version": "1.65.0",
  "sap.app": {
    "id": "sains.ar.customeraccounts",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": { "version": "2.0.0" },
    "dataSources": {
      "mainService": {
        "uri": "/ar/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "fullWidth": false
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.fe.core": {},
        "sap.ushell": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "sains.ar.customeraccounts.i18n.i18n" }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.fe.core.AppComponent",
        "viewType": "XML",
        "async": true
      },
      "routes": [
        {
          "pattern": "",
          "name": "CustomerAccountsList",
          "target": "CustomerAccountsList"
        },
        {
          "pattern": "CustomerAccounts({key})",
          "name": "CustomerAccountsObjectPage",
          "target": "CustomerAccountsObjectPage"
        }
      ],
      "targets": {
        "CustomerAccountsList": {
          "type": "Component",
          "id": "CustomerAccountsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "CustomerAccounts",
              "variantManagement": "Page",
              "initialLoad": "Auto",
              "navigation": {
                "CustomerAccounts": {
                  "detail": { "route": "CustomerAccountsObjectPage" }
                }
              }
            }
          }
        },
        "CustomerAccountsObjectPage": {
          "type": "Component",
          "id": "CustomerAccountsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "CustomerAccounts",
              "editableHeaderContent": false,
              "navigation": {
                "invoices": { "detail": { "route": "InvoicesObjectPage" } },
                "payments": { "detail": { "route": "PaymentsObjectPage" } }
              }
            }
          }
        }
      }
    }
  }
}
