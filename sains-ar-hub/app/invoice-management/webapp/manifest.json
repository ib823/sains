{
  "_version": "1.65.0",
  "sap.app": {
    "id": "sains.ar.invoicemanagement",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": { "version": "2.0.0" },
    "dataSources": {
      "mainService": {
        "uri": "/ar/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": { "sap.m": {}, "sap.ui.core": {}, "sap.fe.templates": {}, "sap.fe.core": {} }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "settings": { "synchronizationMode": "None", "operationMode": "Server", "autoExpandSelect": true }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "sains.ar.invoicemanagement.i18n.i18n" }
      }
    },
    "routing": {
      "config": { "routerClass": "sap.fe.core.AppComponent" },
      "routes": [
        { "pattern": "", "name": "InvoicesList", "target": "InvoicesList" },
        { "pattern": "Invoices({key})", "name": "InvoicesObjectPage", "target": "InvoicesObjectPage" }
      ],
      "targets": {
        "InvoicesList": {
          "type": "Component", "id": "InvoicesList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "Invoices",
              "variantManagement": "Page",
              "initialLoad": "Auto"
            }
          }
        },
        "InvoicesObjectPage": {
          "type": "Component", "id": "InvoicesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": { "settings": { "entitySet": "Invoices" } }
        }
      }
    }
  }
}
