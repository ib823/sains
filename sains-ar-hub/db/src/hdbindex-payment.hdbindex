INDEX sains_ar_payment_account_date ON "SAINS_AR_PAYMENT"("ACCOUNT_ID","PAYMENTDATE");
INDEX sains_ar_payment_status ON "SAINS_AR_PAYMENT"("STATUS")
  WHERE "STATUS" IN ('RECEIVED','UNALLOCATED','CLEARING_PENDING');
INDEX sains_ar_payment_channel ON "SAINS_AR_PAYMENT"("CHANNEL","PAYMENTDATE");
INDEX sains_ar_payment_batch ON "SAINS_AR_PAYMENT"("BATCHREFERENCE")
  WHERE "BATCHREFERENCE" IS NOT NULL;
