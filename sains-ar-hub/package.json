    },
    "features": {
      "fiori_preview": true
    },
    "fiori": {
      "preview": {
        "ui5": {
          "version": "",
          "theme": "sap_horizon"
        }
      }
    },
    "build": {
      "target": "gen",
      "tasks": [
        {
          "for": "hana"
        },
        {
          "for": "node-cf"
        }
      ]
    },
    "hana": {
      "deploy-format": "hdbtable",
      "journal": {
        "change-mode": "alter"
      }
    },
    "log": {
      "service": true
    },
    "server": {
      "port": 4004,
      "cors": true
    }
  }
}
