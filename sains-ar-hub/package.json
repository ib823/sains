{
  "name": "sains-ar-hub",
  "version": "2.0.0",
  "description": "SAINS BTP AR Hub — Accounts Receivable Management for Water Utility",
  "repository": {
    "type": "git",
    "url": "/* TBC: SAINS git repository URL */"
  },
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
    "build": "cds build --production",
    "test": "jest --testPathPattern=test/unit",
    "test:integration": "jest --testPathPattern='test/integration/(?!phase2)' --runInBand",
    "test:perf": "node test/performance/load-scenarios.js",
    "test:all": "jest",
    "test:integration:phase2": "jest test/integration/phase2-* --testTimeout=30000 --runInBand",
    "lint": "eslint srv/ --ext .js",
    "start:poc": "CDS_ENV=poc npx cds deploy && CDS_ENV=poc cds-serve",
    "deploy:cf": "cf blue-green-deploy sains-ar-hub -f manifest.yml",
    "deploy:hdi": "cds deploy --to hana"
  },
  "dependencies": {
    "@cap-js/sqlite": "^1.11.1",
    "@sap/audit-logging": "^5.8.0",
    "@sap/cds": "^8.0.0",
    "@sap/cds-dk": "^8.0.0",
    "@sap/hana-client": "^2.20.0",
    "@sap/xssec": "^3.6.0",
    "autocannon": "^7.12.0",
    "axios": "1.14.0",
    "dayjs": "^1.11.0",
    "decimal.js": "^10.4.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.1",
    "fast-xml-parser": "^5.5.8",
    "mt940-js": "^1.0.0",
    "node-cron": "^4.2.1",
    "node-forge": "^1.3.1",
    "passport": "^0.7.0",
    "qrcode": "^1.5.3",
    "ssh2-sftp-client": "^12.1.0",
    "tslib": "^2.8.1",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@cap-js/sqlite": "^1.11.1",
    "@jest/globals": "^29.0.0",
    "@sap/eslint-plugin-cds": "^3.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "supertest": "^6.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "srv/**/*.js",
      "!srv/external/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    }
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "hana-cloud",
        "deploy-format": "hdbtable"
      },
      "uaa": {
        "kind": "xsuaa"
      },
      "audit-log": {
        "kind": "audit-log-service",
        "vcap": {
          "label": "auditlog"
        }
      },
      "[development]": {
        "db": {
          "kind": "sqlite",
          "credentials": {
            "database": ":memory:"
          }
        },
        "auth": {
          "kind": "mocked",
          "users": {
            "test-user": {
              "password": "test",
              "roles": [
                "authenticated-user",
                "FinanceAdmin",
                "FinanceSupervisor",
                "FinanceManager",
                "BILStaff",
                "BILSupervisor",
                "CounterStaff",
                "CounterSupervisor",
                "CollectionsOfficer",
                "CollectionsSupervisor",
                "ReportViewer",
                "SystemAdmin"
              ]
            },
            "iwrs-system": {
              "password": "iwrs-test-password",
              "roles": [
                "iWRSServiceAccount",
                "SystemProcess"
              ]
            },
            "metis-system": {
              "password": "metis-test-password",
              "roles": [
                "MetisServiceAccount",
                "SystemProcess"
              ]
            },
            "customer-alice": {
              "password": "customer-test-password",
              "roles": [
                "Customer"
              ],
              "attr": {
                "sains_account_numbers": [
                  "10000000001"
                ]
              }
            }
          }
        }
      },
      "[poc]": {
        "db": {
          "kind": "sqlite",
          "credentials": {
            "database": "db/sains-poc.sqlite"
          }
        },
        "auth": {
          "kind": "mocked",
          "users": {
            "test-user": {
              "password": "test",
              "roles": [
                "authenticated-user",
                "FinanceAdmin",
                "FinanceSupervisor",
                "FinanceManager",
                "BILStaff",
                "BILSupervisor",
                "CounterStaff",
                "CounterSupervisor",
                "CollectionsOfficer",
                "CollectionsSupervisor",
                "ReportViewer",
                "SystemAdmin"
              ]
            },
            "iwrs-system": {
              "password": "iwrs-test-password",
              "roles": [
                "iWRSServiceAccount",
                "SystemProcess"
              ]
            },
            "metis-system": {
              "password": "metis-test-password",
              "roles": [
                "MetisServiceAccount",
                "SystemProcess"
              ]
            },
            "customer-alice": {
              "password": "customer-test-password",
              "roles": [
                "Customer"
              ],
              "attr": {
                "sains_account_numbers": [
                  "10000000001"
                ]
              }
            },
            "customer-bob": {
              "password": "customer-test-password",
              "roles": [
                "Customer"
              ],
              "attr": {
                "sains_account_numbers": [
                  "1000000002"
                ]
              }
            },
            "customer-chong": {
