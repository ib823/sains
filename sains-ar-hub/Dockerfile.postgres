FROM node:20-slim AS builder
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev
COPY . .

FROM node:20-slim
WORKDIR /app
RUN addgroup --system app && adduser --system --ingroup app app
COPY --from=builder /app .
RUN chown -R app:app /app
USER app
ENV NODE_ENV=production
ENV CDS_ENV=postgres-cloud
EXPOSE 4004
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s CMD curl -f http://localhost:4004/health || exit 1
CMD ["npx", "cds-serve"]
