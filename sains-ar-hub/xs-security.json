{
  "xsappname": "sains-ar-hub",
  "tenant-mode": "dedicated",
  "oauth2-configuration": {
    "token-validity": 3600,
    "refresh-token-validity": 43200,
    "grant-types": [
      "authorization_code",
      "client_credentials",
      "refresh_token",
      "urn:ietf:params:oauth:grant-type:jwt-bearer"
    ],
    "redirect-uris": [
      "https://*.hana.ondemand.com/**",
      "http://localhost:*/**"
    ]
  },
  "authorities": ["$XSAPPNAME.SystemProcess"],
  "scopes": [
    { "name": "$XSAPPNAME.FinanceAdmin",      "description": "Finance Administrator" },
    { "name": "$XSAPPNAME.FinanceSupervisor", "description": "Finance Supervisor" },
    { "name": "$XSAPPNAME.FinanceManager",    "description": "Finance Manager" },
    { "name": "$XSAPPNAME.CFO",               "description": "Chief Financial Officer" },
    { "name": "$XSAPPNAME.BILStaff",          "description": "BIL Staff" },
    { "name": "$XSAPPNAME.BILSupervisor",     "description": "BIL Supervisor" },
    { "name": "$XSAPPNAME.CounterStaff",      "description": "Counter Staff" },
    { "name": "$XSAPPNAME.ICTManager",        "description": "ICT Manager" },
    { "name": "$XSAPPNAME.Auditor",           "description": "External Auditor — read-only" },
    { "name": "$XSAPPNAME.SystemProcess",     "description": "Automated batch jobs and integrations" },
    { "name": "$XSAPPNAME.iWRSServiceAccount", "description": "iWRS system account scope" },
    { "name": "$XSAPPNAME.MetisServiceAccount", "description": "Metis system account scope" },
    { "name": "$XSAPPNAME.Customer", "description": "Authenticated customer — iSAINS portal and mobile app" },
    { "name": "$XSAPPNAME.iSAINSServiceAccount", "description": "iSAINS portal service account for system-to-system calls" },
    { "name": "$XSAPPNAME.BayaranPukalServiceAccount", "description": "Bayaran Pukal system service account" }
  ],
  "role-templates": [
    { "name": "FinanceAdmin",     "scope-references": ["$XSAPPNAME.FinanceAdmin"] },
    { "name": "FinanceSupervisor","scope-references": ["$XSAPPNAME.FinanceAdmin","$XSAPPNAME.FinanceSupervisor"] },
    { "name": "FinanceManager",   "scope-references": ["$XSAPPNAME.FinanceAdmin","$XSAPPNAME.FinanceSupervisor","$XSAPPNAME.FinanceManager"] },
    { "name": "CFO",              "scope-references": ["$XSAPPNAME.FinanceAdmin","$XSAPPNAME.FinanceSupervisor","$XSAPPNAME.FinanceManager","$XSAPPNAME.CFO"] },
    { "name": "BILStaff",         "scope-references": ["$XSAPPNAME.BILStaff"] },
    { "name": "BILSupervisor",    "scope-references": ["$XSAPPNAME.BILStaff","$XSAPPNAME.BILSupervisor"] },
    { "name": "CounterStaff",     "scope-references": ["$XSAPPNAME.CounterStaff"] },
    { "name": "ICTManager",       "scope-references": ["$XSAPPNAME.ICTManager"] },
    { "name": "Auditor",          "scope-references": ["$XSAPPNAME.Auditor"] },
    { "name": "SystemProcess",    "scope-references": ["$XSAPPNAME.SystemProcess"] },
    { "name": "iWRSServiceAccount", "scope-references": ["$XSAPPNAME.iWRSServiceAccount"] },
    { "name": "MetisServiceAccount", "scope-references": ["$XSAPPNAME.MetisServiceAccount"] },
    { "name": "Customer", "scope-references": ["$XSAPPNAME.Customer"] },
    { "name": "iSAINSServiceAccount", "scope-references": ["$XSAPPNAME.iSAINSServiceAccount","$XSAPPNAME.Customer"] },
    { "name": "BayaranPukalServiceAccount", "scope-references": ["$XSAPPNAME.BayaranPukalServiceAccount"] }
  ]
}
