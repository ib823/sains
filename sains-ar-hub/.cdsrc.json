{
  "build": {
    "target": "gen",
    "tasks": [
      { "for": "hana", "src": "db", "options": { "model": ["db","srv","app"] } },
      { "for": "node-cf", "src": "srv", "options": { "model": ["db","srv","app"] } }
    ]
  },
  "requires": {
    "[development]": {
      "db": { "kind": "sqlite", "credentials": { "database": ":memory:" } },
      "uaa": { "kind": "dummy" }
    },
    "[poc]": {
      "db": { "kind": "sqlite", "credentials": { "database": "db/sains-poc.sqlite" } },
      "uaa": { "kind": "dummy" }
    },
    "[postgres]": {
      "db": {
        "kind": "postgres",
        "impl": "@cap-js/postgres",
        "credentials": {
          "url": "${DATABASE_URL:-postgresql://localhost:5432/sains_ar_hub}"
        }
      },
      "uaa": { "kind": "dummy" }
    },
    "[postgres-cloud]": {
      "db": {
        "kind": "postgres",
        "impl": "@cap-js/postgres",
        "credentials": {
          "url": "${DATABASE_URL}",
          "ssl": { "rejectUnauthorized": false }
        },
        "pool": {
          "min": 1,
          "max": 5,
          "acquireTimeoutMillis": 60000,
          "idleTimeoutMillis": 30000,
          "evictionRunIntervalMillis": 10000
        }
      },
      "uaa": { "kind": "dummy" }
    },
    "[production]": {
      "db": { "kind": "hana-cloud" },
      "uaa": { "kind": "xsuaa" },
      "audit-log": { "kind": "audit-log-service" }
    }
  },
  "i18n": { "default_language": "en", "languages": ["en","ms"] },
  "sql": { "native_hana_associations": true }
}
